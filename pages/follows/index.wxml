<view class="container {{theme === 'dark' ? 'dark' : ''}} {{elderMode ? 'elder-mode' : ''}}">
  <!-- 背景装饰 -->
  <view class="bg-decorations">
    <image class="bg-mountain" src="/images/backgrounds/山脉.jpg" mode="aspectFill"></image>
  </view>
  
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="navigateBack">
      <text class="nav-back">‹</text>
    </view>
    <view class="nav-title">我的关注</view>
    <view class="nav-right"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 关注列表 -->
    <view wx:if="{{!empty}}" class="follows-list">
      <view wx:for="{{followingList}}" wx:key="_openid" class="follow-card card" bindtap="goToUserDetail" data-id="{{item._openid}}">
        <!-- 用户信息 -->
        <view class="follow-header">
          <image class="avatar" src="{{item.avatar || 'https://picsum.photos/200/200?random=3'}}" mode="aspectFill"></image>
          <view class="user-info">
            <text class="nickname">{{item.nickname || '用户'}}</text>
            <view class="tags">
              <text class="tag role">{{item.role || '村民'}}</text>
              <text class="tag area" wx:if="{{item.area}}">{{item.area}}</text>
            </view>
          </view>
        </view>

        <!-- 简介 -->
        <view class="bio" wx:if="{{item.bio}}">{{item.bio}}</view>

        <!-- 统计信息 -->
        <view class="stats">
          <view class="stat-item">
            <text class="stat-number">{{item.postCount || 0}}</text>
            <text class="stat-label">发布</text>
          </view>
          <view class="stat-item">
            <text class="stat-number">{{item.followerCount || 0}}</text>
            <text class="stat-label">粉丝</text>
          </view>
          <view class="stat-item">
            <text class="stat-number">{{item.followingCount || 0}}</text>
            <text class="stat-label">关注</text>
          </view>
        </view>

        <!-- 取消关注按钮 -->
        <view class="action-bar" catchTap="unfollow" data-id="{{item._openid}}" data-index="{{index}}">
          <text class="unfollow-btn">取消关注</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{empty}}" class="empty-state">
      <view class="empty-icon">💔</view>
      <text class="empty-text">还没有关注任何人</text>
      <text class="empty-desc">去发现更多有趣的人吧</text>
      <view class="empty-btn" bindtap="navigateBack">返回</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading && followingList.length === 0}}" class="loading">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{!hasMore && followingList.length > 0}}" class="load-more-tip">
      已经到底了
    </view>
  </view>
</view>
